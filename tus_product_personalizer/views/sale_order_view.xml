<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="view_order_form" model="ir.ui.view">
        <field name="name">sale.order.form.tagsen</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="is_personalizer_order" invisible="1"/>
                <button
                    name="action_print_production_sheet"
                    type="object"
                    string="Production Sheet"
                    class="btn-secondary"
                    invisible="not is_personalizer_order"
                />
                <button
                    name="action_regenerate_production_sheet"
                    type="object"
                    string="Regenerate Production Sheet"
                    class="btn-secondary"
                    invisible="not is_personalizer_order or state in ('draft', 'sent', 'cancel')"
                />
            </xpath>
            <xpath
                expr="//page[@name='order_lines']/field[@name='order_line']/list/field[@name='product_template_id']"
                position="after"
            >
                <field name="printing_method_id" widget="many2one" options="{'no_create': True}"/>
                <field name="uploaded_design_ids" column_invisible="1" />
                <field name="is_personalizer_configured" column_invisible="1" />
                <field name="vdp_enabled" column_invisible="1" />
                <field name="vdp_record_count" column_invisible="1" />
                <field name="empty_canvas_width" column_invisible="1" />
                <field name="empty_canvas_height" column_invisible="1" />
                <field name="empty_canvas_unit" column_invisible="1" />
                <field name="empty_canvas_sides" column_invisible="1" />
                <field name="empty_canvas_machining_folding" column_invisible="1" />
                <field name="empty_canvas_machining_cutting" column_invisible="1" />
                <field name="empty_canvas_machining_corner_drilling" column_invisible="1" />
                <field name="empty_canvas_size_label" string="Canvas Size" optional="show"/>
                <field name="empty_canvas_finish_label" string="Finish" optional="show"/>
                <field name="empty_canvas_print_quality_label" string="Print Quality" optional="show"/>
                <field name="empty_canvas_print_mode_label" string="Print Mode" optional="show"/>
                <field name="empty_canvas_machining_summary" string="Basic Machining" optional="show"/>
                <field name="empty_canvas_finish" column_invisible="1"/>
                <field name="empty_canvas_print_quality" column_invisible="1"/>
                <field name="empty_canvas_print_mode" column_invisible="1"/>
                <button
                    name="view_uploaded_design"
                    type="object"
                    string="View Design"
                    class="oe_highlight"
                    invisible="not uploaded_design_ids or not is_personalizer_configured"
                />
                <button
                    name="create_design"
                    type="object"
                    string="Create Design"
                    class="oe_highlight"
                    invisible="uploaded_design_ids or not is_personalizer_configured"
                />
                <button
                    name="view_vdp_records"
                    type="object"
                    string="VDP Rows"
                    class="btn-secondary"
                    invisible="not vdp_enabled"
                />
            </xpath>
            <xpath
                expr="//page[@name='order_lines']/field[@name='order_line']/form//div[@name='lead']/parent::group"
                position="before"
            >
                <group string="Canvas Configuration" invisible="not empty_canvas_size_label">
                    <field name="empty_canvas_size_label" readonly="1"/>
                    <field name="empty_canvas_finish_label" readonly="1"/>
                    <field name="empty_canvas_print_quality_label" readonly="1"/>
                    <field name="empty_canvas_print_mode_label" readonly="1"/>
                    <field name="empty_canvas_machining_summary" readonly="1"/>
                    <field name="empty_canvas_machining_codes" readonly="1" invisible="1"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
