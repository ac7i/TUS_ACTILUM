<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="orderline_design_upload_view_list" model="ir.ui.view">
            <field name="name">orderline.design.upload.view</field>
            <field name="model">orderline.design.upload</field>
            <field name="arch" type="xml">
                <list string="Uploaded Design">
                    <field name="name"/>
                    <field name="order_id"/>
                    <field name="order_line"/>
                    <field name="uploaded_type"/>
                </list>
            </field>
        </record>

        <record id="orderline_design_upload_view_form" model="ir.ui.view">
            <field name="name">orderline.design.upload.form</field>
            <field name="model">orderline.design.upload</field>
            <field name="arch" type="xml">
                <form string="Upload Design">
                    <header>
                        <button name="action_download_svg"
                                type="object"
                                string="Download SVG"
                                class="btn-primary"
                                icon="fa-download"/>
                        <button name="action_download_ai"
                                type="object"
                                string="Download AI"
                                class="btn-secondary"
                                icon="fa-download"
                                invisible="not design_ai"/>
                        <button name="action_download_design"
                                type="object"
                                string="Download Preview (PNG)"
                                invisible="not uploaded_attachment"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Order">
                                <field name="order_id" readonly="1"/>
                                <field name="order_line" readonly="1"/>
                                <field name="uploaded_type" readonly="1"/>
                            </group>
                            <group string="Print Size">
                                <label for="print_width" string="Dimensions"/>
                                <div class="o_row">
                                    <field name="print_width" readonly="1" class="oe_inline"/>
                                    <span>×</span>
                                    <field name="print_height" readonly="1" class="oe_inline"/>
                                    <field name="print_unit" readonly="1" class="oe_inline"/>
                                </div>
                                <field name="canvas_background_color" widget="color" readonly="1"/>
                                <field name="empty_canvas_margin_mm" readonly="1"/>
                                <field name="finish_varnish_type" readonly="1"/>
                                <field name="finish_relief_mm" readonly="1"/>
                            </group>
                        </group>
                        <group string="Design Preview">
                            <field name="uploaded_attachment_rel"
                                   widget="image"
                                   readonly="1"
                                   nolabel="1"
                                   class="tus-orderline-design-preview"/>
                            <field name="uploaded_attachment" invisible="1"/>
                            <field name="design_svg" invisible="1"/>
                            <field name="design_ai" invisible="1"/>
                        </group>
                        <notebook>
                            <page string="Imprint Elements" name="imprint_elements">
                                <field name="design_ids" readonly="1" nolabel="1">
                                    <list create="0" delete="0" edit="0" open_form_view="1">
                                        <field name="element_label" string="Element"/>
                                        <field name="tus_finish_effect" string="Finish" optional="show"/>
                                        <field name="tus_foil_metal" string="Foil" optional="hide"/>
                                        <field name="size_display" string="Size"/>
                                        <field name="color_display" string="Colors"/>
                                        <field name="tus_varnish_type" string="Varnish" optional="hide"/>
                                        <field name="tus_relief_mm" string="Relief (mm)" optional="hide"/>
                                        <field name="imprint_image" column_invisible="1"/>
                                        <field name="imprint_design_attribute" column_invisible="1"/>
                                        <field name="imprint_width" column_invisible="1"/>
                                        <field name="imprint_height" column_invisible="1"/>
                                        <field name="imprint_width_uom" column_invisible="1"/>
                                        <field name="imprint_height_uom" column_invisible="1"/>
                                        <field name="imprint_colors" column_invisible="1"/>
                                        <field name="imprint_cmyk" column_invisible="1"/>
                                        <field name="printable_color_id" column_invisible="1"/>
                                        <button name="action_download_imprint"
                                                type="object"
                                                string="PNG"
                                                icon="fa-download"
                                                invisible="not imprint_image"/>
                                        <button name="action_download_imprint_svg"
                                                type="object"
                                                string="SVG"
                                                icon="fa-download"/>
                                    </list>
                                    <form string="Imprint Element">
                                        <header>
                                            <button name="action_download_imprint"
                                                    type="object"
                                                    string="Download PNG"
                                                    invisible="not imprint_image"/>
                                            <button name="action_download_imprint_svg"
                                                    type="object"
                                                    string="Download SVG"
                                                    class="btn-primary"/>
                                        </header>
                                        <sheet>
                                            <div class="oe_title">
                                                <h1>
                                                    <field name="element_label" readonly="1"/>
                                                </h1>
                                            </div>
                                            <group>
                                                <group string="Preview">
                                                    <field name="imprint_image"
                                                           widget="image"
                                                           readonly="1"
                                                           nolabel="1"
                                                           class="tus-imprint-preview"/>
                                                </group>
                                                <group string="Print Specs">
                                                    <field name="tus_finish_effect" readonly="1"/>
                                                    <field name="tus_foil_metal" readonly="1"
                                                           invisible="tus_finish_effect not in ('foil', 'foil_emboss')"/>
                                                    <field name="tus_relief_mm" readonly="1"/>
                                                    <field name="tus_varnish_type" readonly="1"/>
                                                    <label for="imprint_width" string="Dimensions"/>
                                                    <div class="o_row">
                                                        <field name="imprint_width" readonly="1" class="oe_inline"/>
                                                        <span>×</span>
                                                        <field name="imprint_height" readonly="1" class="oe_inline"/>
                                                        <field name="imprint_width_uom" readonly="1" class="oe_inline"/>
                                                    </div>
                                                    <field name="imprint_colors" readonly="1"/>
                                                    <field name="imprint_cmyk" readonly="1"/>
                                                    <field name="printable_color_id" readonly="1"/>
                                                </group>
                                            </group>
                                            <notebook groups="base.group_no_one">
                                                <page string="Technical JSON" name="technical_json">
                                                    <field name="imprint_design_attribute" invisible="1"/>
                                                    <field name="imprint_design_display"
                                                           widget="ace"
                                                           options="{'mode': 'javascript'}"
                                                           readonly="1"
                                                           nolabel="1"
                                                           class="tus-imprint-json-display"/>
                                                </page>
                                            </notebook>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_upload_design" model="ir.actions.act_window">
            <field name="name">Upload Design</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">orderline.design.upload</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new record!
                </p>
            </field>
        </record>

        <menuitem
            id="upload_design_menu"
            name="Upload Design"
            parent="sale.menu_sale_config"
            action="action_upload_design"
            sequence="30"
        />
    </data>
</odoo>
