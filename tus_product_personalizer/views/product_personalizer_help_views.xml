<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_personalizer_help_list" model="ir.ui.view">
        <field name="name">product.personalizer.help.list</field>
        <field name="model">product.personalizer.help</field>
        <field name="arch" type="xml">
            <list string="Designer Help">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="context_key"/>
                <field name="active"/>
                <field name="share_url" widget="url"/>
            </list>
        </field>
    </record>

    <record id="view_product_personalizer_help_form" model="ir.ui.view">
        <field name="name">product.personalizer.help.form</field>
        <field name="model">product.personalizer.help</field>
        <field name="arch" type="xml">
            <form string="Designer Help">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="active" widget="boolean_toggle"/>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Help title"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="context_key"/>
                            <field name="sequence"/>
                            <field name="video_url" placeholder="https://www.youtube.com/watch?v=..."/>
                            <field name="video_embed_url" readonly="1" invisible="not video_url"/>
                        </group>
                        <group>
                            <field name="share_url" widget="url" readonly="1"/>
                            <field name="share_token" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Help Content" name="content">
                            <field name="body" widget="html" options="{'style-inline': true}"/>
                        </page>
                    </notebook>
                    <group string="Notes" colspan="2">
                        <div colspan="2" class="text-muted">
                            <p>Only one help record can be active per context (Main, Product, Add Image, etc.). Activating this record will deactivate any other active help for the same context.</p>
                            <p>The shareable link always shows your latest help content and video after you save. The link itself does not change when you update the video.</p>
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_personalizer_help" model="ir.actions.act_window">
        <field name="name">Designer Help</field>
        <field name="res_model">product.personalizer.help</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create designer help content for your customers.
            </p>
            <p>
                Add text, images, and videos. Only one record can be active at a time.
            </p>
        </field>
    </record>

</odoo>
