<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_design_template_list" model="ir.ui.view">
        <field name="name">product.design.template.list</field>
        <field name="model">product.design.template</field>
        <field name="arch" type="xml">
            <list string="Design Templates" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="preview_image" widget="image" options="{'size': [64, 64]}"/>
                <field name="name"/>
                <field name="design_format"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_product_design_template_form" model="ir.ui.view">
        <field name="name">product.design.template.form</field>
        <field name="model">product.design.template</field>
        <field name="arch" type="xml">
            <form string="Design Template">
                <sheet>
                    <field name="preview_image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Template name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="product_tmpl_id" readonly="1"/>
                            <field name="design_format"/>
                            <field name="is_default"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="design_data" filename="design_data_filename"/>
                            <field name="design_data_filename" invisible="1"/>
                            <field name="layer_metadata" widget="json"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_design_template_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Design Template</field>
        <field name="res_model">design.template.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_design_template_import_wizard_form" model="ir.ui.view">
        <field name="name">design.template.import.wizard.form</field>
        <field name="model">design.template.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Design Template">
                <group>
                    <field name="product_tmpl_id" readonly="1"/>
                    <field name="name"/>
                    <field name="design_format"/>
                    <field name="preview_image" widget="image"/>
                    <field name="design_data" filename="design_data_filename"/>
                    <field name="design_data_filename" invisible="1"/>
                    <field name="is_default"/>
                </group>
                <footer>
                    <button name="action_import" type="object" string="Import" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_design_template_sheet_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Templates from Excel</field>
        <field name="res_model">design.template.sheet.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_design_template_sheet_import_wizard_form" model="ir.ui.view">
        <field name="name">design.template.sheet.import.wizard.form</field>
        <field name="model">design.template.sheet.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Templates from Excel">
                <group>
                    <field name="product_tmpl_id" readonly="1"/>
                    <field name="xlsx_file" filename="xlsx_filename"/>
                    <field name="xlsx_filename" invisible="1"/>
                    <field name="assets_zip" filename="assets_zip_filename"/>
                    <field name="assets_zip_filename" invisible="1"/>
                </group>
                <group string="Instructions">
                    <div colspan="2" class="text-muted">
                        <p>1. Download the sample Excel sheet and fill in one row per template.</p>
                        <p>2. Pack SVG/JSON design files (and optional preview PNG/JPG) into a ZIP.</p>
                        <p>3. Use paths in the sheet that match files inside the ZIP, e.g. <code>designs/card-01.svg</code>.</p>
                        <p><b>Required columns:</b> name, design_file</p>
                        <p><b>Optional columns:</b> sequence, design_format, preview_file, is_default, active</p>
                    </div>
                </group>
                <field name="import_log" invisible="not import_log" nolabel="1" colspan="2"/>
                <footer>
                    <button name="action_download_sample" type="object"
                            string="Download Sample Sheet" class="btn-secondary"/>
                    <button name="action_import" type="object"
                            string="Import Templates" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
