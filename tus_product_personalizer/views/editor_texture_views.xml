<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_editor_texture_list" model="ir.ui.view">
        <field name="name">editor.texture.list</field>
        <field name="model">editor.texture</field>
        <field name="arch" type="xml">
            <list string="Texture Library" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="preview_image" widget="image" options="{'size': [64, 64]}"/>
                <field name="name"/>
                <field name="category"/>
                <field name="price_per_sqm"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_editor_texture_form" model="ir.ui.view">
        <field name="name">editor.texture.form</field>
        <field name="model">editor.texture</field>
        <field name="arch" type="xml">
            <form string="Texture">
                <sheet>
                    <field name="texture_file" widget="image" class="oe_avatar" filename="texture_file_filename"/>
                    <field name="preview_image" invisible="1"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Texture name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="price_per_sqm"/>
                        </group>
                        <group>
                            <field name="texture_file_filename" invisible="1"/>
                        </group>
                    </group>
                    <group string="Instructions">
                        <div colspan="2" class="text-muted">
                            <p>Upload a texture image. Price per m² is multiplied by the customer's printable area.</p>
                            <p>In the designer the texture is centered, cover-scaled, and locked as the background layer.</p>
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_editor_texture" model="ir.actions.act_window">
        <field name="name">Texture Library</field>
        <field name="res_model">editor.texture</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
