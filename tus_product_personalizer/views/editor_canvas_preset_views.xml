<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_editor_canvas_preset" model="ir.actions.act_window">
        <field name="name">Canvas Size Presets</field>
        <field name="res_model">editor.canvas.preset</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_editor_canvas_preset_list" model="ir.ui.view">
        <field name="name">editor.canvas.preset.list</field>
        <field name="model">editor.canvas.preset</field>
        <field name="arch" type="xml">
            <list string="Canvas Size Presets">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="width"/>
                <field name="height"/>
                <field name="unit"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_editor_canvas_preset_form" model="ir.ui.view">
        <field name="name">editor.canvas.preset.form</field>
        <field name="model">editor.canvas.preset</field>
        <field name="arch" type="xml">
            <form string="Canvas Size Preset">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="width"/>
                            <field name="height"/>
                            <field name="unit"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
