<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Reusable POD product loader (t-shirt → cap → mug → bottle) -->
    <template id="product_loader_markup" name="TUS Product Loader">
        <div class="tus-product-loader" role="img" aria-label="Loading">
            <div class="tus-product-loader__ring" aria-hidden="true"/>
            <div class="tus-product-loader__icons" aria-hidden="true">
                <!-- T-shirt -->
                <svg class="tus-product-loader__icon tus-product-loader__icon--shirt" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14 10l4-5h12l4 5 6 3v31H8V13l6-3z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/>
                    <path d="M14 10v8M34 10v8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <!-- Cap -->
                <svg class="tus-product-loader__icon tus-product-loader__icon--cap" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 26c0-8 7.2-13 14-13s14 5 14 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
                    <ellipse cx="24" cy="26" rx="15" ry="5" stroke="currentColor" stroke-width="2" fill="none"/>
                    <path d="M24 20V11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <circle cx="24" cy="9" r="2.5" fill="currentColor"/>
                </svg>
                <!-- Mug -->
                <svg class="tus-product-loader__icon tus-product-loader__icon--mug" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 16h22v24H12V16z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/>
                    <path d="M34 20h5a3 3 0 010 6h-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
                    <path d="M14 16V13a10 10 0 0120 0v3" stroke="currentColor" stroke-width="2" fill="none"/>
                </svg>
                <!-- Bottle -->
                <svg class="tus-product-loader__icon tus-product-loader__icon--bottle" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                    <path d="M19 8h10v5h-3v3h3v26H16V16h3v-3h-3V8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/>
                    <path d="M19 8h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M20 21h8M20 27h8M20 33h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.45"/>
                </svg>
            </div>
        </div>
    </template>
</odoo>
