<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="product_template_attribute_value_view_form_inherit" model="ir.ui.view">
        <field name="name">product.template.attribute.value.form.inherit</field>
        <field name="model">product.template.attribute.value</field>
        <field name="inherit_id" ref="product.product_template_attribute_value_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_copy_views_from_template"
                            type="object"
                            string="Copy from Template"
                            class="btn btn-primary"
                            invisible="is_views_customized"/>
                    <button name="action_reset_views_to_template"
                            type="object"
                            string="Reset to Template"
                            class="btn btn-secondary"
                            invisible="not is_views_customized"/>
                </header>
            </xpath>
            <sheet position="inside">
                <field name="image" widget="image" class="oe_avatar" float="right"/>
                <group string="Print To Web" name="print2web_attr">
                    <field name="is_views_customized" readonly="1" widget="boolean" invisible="1"/>
                    <div invisible="is_views_customized"
                         class="alert alert-info" role="alert">
                        This attribute value inherits views from the product template.
                        Click the button below to copy the template configuration for this specific color.
                        <br/><br/>
                        <button name="action_copy_views_from_template"
                                type="object"
                                string="Copy from Template &amp; Customize"
                                class="btn btn-primary"/>
                    </div>
                    <button name="action_reset_views_to_template"
                            type="object"
                            string="Reset to Template"
                            class="btn btn-secondary"
                            invisible="not is_views_customized"
                            confirm="This will delete all custom views for this attribute value and revert to the template configuration. Continue?"/>
                    <field name="attribute_view_ids" widget="editor_product_ids" nolabel="1">
                        <list string="Views">
                            <field name="title" />
                            <field name="thumbnail" widget="image" options="{'size': [64, 64]}" />
                            <field name="design_areas_json" widget="json" column_invisible="1" />
                        </list>
                        <form string="View">
                            <sheet>
                                <group>
                                    <group>
                                        <field name="title" />
                                        <field name="thumbnail" widget="image" />
                                        <field name="stage_width" />
                                        <field name="stage_height" />
                                        <field name="image_width" />
                                        <field name="image_height" />
                                    </group>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </group>
            </sheet>
        </field>
    </record>

</odoo>
