<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_editor_canvas_product_option" model="ir.actions.act_window">
        <field name="name">Canvas Product Options</field>
        <field name="res_model">editor.canvas.product.option</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_category': 1}</field>
    </record>

    <record id="view_editor_canvas_product_option_search" model="ir.ui.view">
        <field name="name">editor.canvas.product.option.search</field>
        <field name="model">editor.canvas.product.option</field>
        <field name="arch" type="xml">
            <search string="Canvas Product Options">
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <group>
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_editor_canvas_product_option_list" model="ir.ui.view">
        <field name="name">editor.canvas.product.option.list</field>
        <field name="model">editor.canvas.product.option</field>
        <field name="arch" type="xml">
            <list string="Canvas Product Options">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_editor_canvas_product_option_form" model="ir.ui.view">
        <field name="name">editor.canvas.product.option.form</field>
        <field name="model">editor.canvas.product.option</field>
        <field name="arch" type="xml">
            <form string="Canvas Product Option">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="category"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="is_default"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
