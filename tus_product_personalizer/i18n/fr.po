#. module: tus_product_personalizer
#: model:mail.template,body_html:tus_product_personalizer.email_template_design_share_invite
msgid ""
"<div style=\"font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; padding: 30px; background-color: #f8fafc; border-radius: 12px; max-width: 600px; margin: auto; border: 1px solid #e2e8f0;\">\n"
"                <div style=\"text-align: center; margin-bottom: 25px;\">\n"
"                    <span style=\"font-size: 24px; font-weight: bold; color: #4d5038;\">Shared Design Invitation</span>\n"
"                </div>\n"
"                <div style=\"background-color: #ffffff; padding: 25px; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);\">\n"
"                    <p style=\"font-size: 16px; color: #1e293b; margin-top: 0; line-height: 1.6;\">\n"
"                        You have been invited by <strong t-out=\"object.share_id.partner_id.name or 'a designer'\">a designer</strong> to view or collaborate on a product design.\n"
"                    </p>\n"
"                    <p style=\"font-size: 15px; color: #64748b; margin-bottom: 25px; line-height: 1.6;\">\n"
"                        Design: <strong style=\"color: #0f172a;\" t-out=\"object.share_id.product_id.name\">Product Design</strong><br/>\n"
"                        Permission: <strong style=\"color: #0f172a;\" t-out=\"'Can customize' if object.access_mode == 'edit' else 'Can view only'\">Can customize</strong>\n"
"                    </p>\n"
"                    <div style=\"text-align: center; margin: 30px 0;\">\n"
"                        <a t-att-href=\"ctx.get('guest_link')\" style=\"background-color: #4d5038; color: #ffffff; padding: 14px 28px; text-decoration: none; border-radius: 6px; font-weight: bold; font-size: 15px; display: inline-block; box-shadow: 0 4px 6px -1px rgba(77, 80, 56, 0.2);\">\n"
"                            Open Shared Design\n"
"                        </a>\n"
"                    </div>\n"
"                    <p style=\"font-size: 13px; color: #94a3b8; margin-top: 25px; line-height: 1.5; text-align: center;\">\n"
"                        This is a secure private link. Do not share this email with others.\n"
"                    </p>\n"
"                </div>\n"
"                <div style=\"text-align: center; margin-top: 20px; font-size: 12px; color: #94a3b8;\">\n"
"                    Powered by Odoo Product Personalizer\n"
"                </div>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"font-family : 'Helvetica Neue', Helvetica, Arial, sans-serif ; padding : 30px; background-color: #f8fafc; border-radius: 12px; max-width: 600px; margin: auto; border: 1px solid #e2e8f0;\">\n"
"                <div style=\"text-align: center; margin-bottom: 25px;\">\n"
"                    <span style=\"font-size: 24px; font-weight: bold; color: #4d5038;\">Invitation à une conception partagée</span>\n"
"                </div>\n"
"                <div style=\"background-color: #ffffff; padding: 25px; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);\">\n"
"                    <p style=\"font-size : 16px ; couleur : #1e293b ; margin-top : 0 ; hauteur de ligne : 1,6 ;\">\n"
"                        Vous avez été invité par <strong t-out=\"object.share_id.partner_id.name ou 'a designer'\">un designer</strong> à visualiser ou à collaborer sur la conception d'un produit.\n"
"                    </p>\n"
"                    <p style=\"font-size: 15px; color: #64748b; margin-bottom: 25px; line-height: 1.6;\">\n"
"                        Conception : <strong style=\"couleur : #0f172a;\" t-out=\"object.share_id.product_id.name\">Conception de produits</strong><br/>\n"
"                        Autorisation : <strong style=\"color: #0f172a;\" t-out=\"'Peut personnaliser' if object.access_mode == 'edit' else 'Peut afficher uniquement'\">Peut personnaliser</strong>\n"
"                    </p>\n"
"                    <div style=\"text-align: center; margin: 30px 0;\">\n"
"                        <a t-att-href=\"ctx.get('guest_link')\" style=\"background-color: #4d5038; color: #ffffff; padding: 14px 28px; text-decoration: none; border-radius: 6px; font-weight: bold; font-size: 15px; display: inline-block; box-shadow: 0 4px 6px -1px rgba(77, 80, 56, 0,2);\">\n"
"                            Conception partagée ouverte\n"
"                        </a>\n"
"                    </div>\n"
"                    <p style=\"font-size : 13px ; couleur : #94a3b8 ; margin-top : 25px ; hauteur de ligne : 1,5 ; texte-align : center ;\">\n"
"                        Il s'agit d'un lien privé sécurisé. Ne partagez pas cet e-mail avec d'autres.\n"
"                    </p>\n"
"                </div>\n"
"                <div style=\"text-align: center; margin-top: 20px; font-size: 12px; color: #94a3b8;\">\n"
"                    Propulsé par Odoo Product Personalizer\n"
"                </div>\n"
"            </div>"

