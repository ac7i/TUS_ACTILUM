<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_production_sheet_document">
        <t t-call="web.external_layout">
            <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)"/>
            <t t-set="lines_data" t-value="sheet_lines.get(doc.id, [])"/>
            <div class="page">
                <div class="oe_structure"/>

                <h2 class="mt-0 mb-3">Production Sheet</h2>

                <div class="row mb-4">
                    <div class="col-6">
                        <strong>Order</strong>
                        <div t-out="doc.name"/>
                        <strong class="d-block mt-2">Customer</strong>
                        <div t-field="doc.partner_id"
                             t-options='{"widget": "contact", "fields": ["name", "address", "phone", "email"], "no_marker": True}'/>
                    </div>
                    <div class="col-6">
                        <strong>Order Date</strong>
                        <div t-field="doc.date_order" t-options='{"widget": "date"}'/>
                        <t t-if="doc.user_id">
                            <strong class="d-block mt-2">Salesperson</strong>
                            <div t-field="doc.user_id"/>
                        </t>
                        <t t-if="doc.client_order_ref">
                            <strong class="d-block mt-2">Customer Reference</strong>
                            <div t-out="doc.client_order_ref"/>
                        </t>
                    </div>
                </div>

                <t t-foreach="lines_data" t-as="line_data">
                    <div class="mt-4 mb-2" style="page-break-inside: avoid;">
                        <h3 class="border-bottom pb-1" t-out="line_data['product_name']"/>

                        <table class="table table-sm table-bordered mb-3">
                            <tbody>
                                <tr t-if="line_data['product_code']">
                                    <th style="width: 25%;">Product Code</th>
                                    <td t-out="line_data['product_code']"/>
                                </tr>
                                <tr>
                                    <th>Quantity</th>
                                    <td>
                                        <span t-out="line_data['quantity']"/>
                                        <span t-out="line_data['uom']"/>
                                    </td>
                                </tr>
                                <tr t-if="line_data['variant_attributes']">
                                    <th>Variant</th>
                                    <td t-out="line_data['variant_attributes']"/>
                                </tr>
                                <tr t-if="line_data['printing_method']">
                                    <th>Printing Method</th>
                                    <td t-out="line_data['printing_method']"/>
                                </tr>
                                <tr t-if="line_data['canvas_size']">
                                    <th>Canvas Size</th>
                                    <td t-out="line_data['canvas_size']"/>
                                </tr>
                                <tr t-if="line_data['canvas_finish']">
                                    <th>Finish</th>
                                    <td t-out="line_data['canvas_finish']"/>
                                </tr>
                                <tr t-if="line_data['print_quality']">
                                    <th>Print Quality</th>
                                    <td t-out="line_data['print_quality']"/>
                                </tr>
                                <tr t-if="line_data['print_mode']">
                                    <th>Print Mode</th>
                                    <td t-out="line_data['print_mode']"/>
                                </tr>
                                <tr t-if="line_data['machining']">
                                    <th>Machining</th>
                                    <td t-out="line_data['machining']"/>
                                </tr>
                            </tbody>
                        </table>

                        <t t-foreach="line_data['sides']" t-as="side_data">
                            <div class="mt-3" style="page-break-inside: avoid;">
                                <h4>
                                    <span t-out="side_data['side']"/>
                                    <t t-if="side_data['name']"> — <span t-out="side_data['name']"/></t>
                                </h4>

                                <div class="row">
                                    <div class="col-5" t-if="side_data['preview']">
                                        <strong>Design Preview</strong>
                                        <div class="mt-1 mb-2">
                                            <img t-att-src="image_data_uri(side_data['preview'])"
                                                 style="max-width: 100%; max-height: 280px; border: 1px solid #ccc;"/>
                                        </div>
                                    </div>
                                    <div t-attf-class="#{side_data['preview'] and 'col-7' or 'col-12'}">
                                        <table class="table table-sm table-bordered">
                                            <tbody>
                                                <tr t-if="side_data['print_width'] and side_data['print_height']">
                                                    <th style="width: 35%;">Print Dimensions</th>
                                                    <td>
                                                        <span t-out="side_data['print_width']"/> ×
                                                        <span t-out="side_data['print_height']"/>
                                                        <span t-out="side_data['print_unit']"/>
                                                    </td>
                                                </tr>
                                                <tr t-if="side_data['margin_mm']">
                                                    <th>Print Margin</th>
                                                    <td><span t-out="side_data['margin_mm']"/> mm</td>
                                                </tr>
                                                <tr t-if="side_data['background_color']">
                                                    <th>Background</th>
                                                    <td t-out="side_data['background_color']"/>
                                                </tr>
                                                <tr t-if="side_data['texture_name']">
                                                    <th>Texture</th>
                                                    <td>
                                                        <span t-out="side_data['texture_name']"/>
                                                        <t t-if="side_data['texture_area_m2']">
                                                            (<span t-out="side_data['texture_area_m2']"/> m²)
                                                        </t>
                                                    </td>
                                                </tr>
                                                <tr t-if="side_data['texture_intensity']">
                                                    <th>Texture Intensity</th>
                                                    <td t-out="side_data['texture_intensity']"/>
                                                </tr>
                                                <tr t-if="side_data['texture_filename']">
                                                    <th>Texture File</th>
                                                    <td t-out="side_data['texture_filename']"/>
                                                </tr>
                                                <tr t-if="side_data['varnish_type']">
                                                    <th>Varnish</th>
                                                    <td t-out="side_data['varnish_type']"/>
                                                </tr>
                                                <tr t-if="side_data['varnish_cover_mode']">
                                                    <th>Varnish Coverage</th>
                                                    <td t-out="side_data['varnish_cover_mode']"/>
                                                </tr>
                                                <tr t-if="side_data['varnish_zones']">
                                                    <th>Varnish Zones</th>
                                                    <td t-out="side_data['varnish_zones']"/>
                                                </tr>
                                                <tr t-if="side_data['varnish_filename']">
                                                    <th>Varnish File</th>
                                                    <td t-out="side_data['varnish_filename']"/>
                                                </tr>
                                                <tr t-if="side_data['finish_relief_mm']">
                                                    <th>Side Relief</th>
                                                    <td><span t-out="side_data['finish_relief_mm']"/> mm</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <t t-if="side_data['imprints']">
                                    <strong>Imprint Elements</strong>
                                    <table class="table table-sm table-bordered mt-1 mb-2">
                                        <thead>
                                            <tr>
                                                <th>Element</th>
                                                <th>Size</th>
                                                <th>Colors</th>
                                                <th>Finish</th>
                                                <th>Varnish</th>
                                                <th>Foil</th>
                                                <th>Relief (mm)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="side_data['imprints']" t-as="imprint">
                                                <td t-out="imprint['label']"/>
                                                <td t-out="imprint['size']"/>
                                                <td t-out="imprint['colors']"/>
                                                <td t-out="imprint['finish']"/>
                                                <td t-out="imprint['varnish']"/>
                                                <td t-out="imprint['foil']"/>
                                                <td t-out="imprint['relief_mm']"/>
                                            </tr>
                                        </tbody>
                                    </table>
                                </t>

                                <t t-if="side_data['files']">
                                    <strong>Production Files</strong>
                                    <table class="table table-sm table-bordered mt-1 mb-2">
                                        <thead>
                                            <tr>
                                                <th>File</th>
                                                <th>Type</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="side_data['files']" t-as="file_item">
                                                <td t-out="file_item['name']"/>
                                                <td t-out="file_item['type']"/>
                                            </tr>
                                        </tbody>
                                    </table>
                                </t>
                            </div>
                        </t>

                        <t t-if="line_data['vdp']">
                            <div class="mt-3" style="page-break-inside: avoid;">
                                <h4>Variable Data Printing</h4>
                                <p>
                                    <span t-out="line_data['vdp']['count']"/> row(s)
                                </p>
                                <table class="table table-sm table-bordered">
                                    <thead>
                                        <tr>
                                            <th>Row</th>
                                            <th>Status</th>
                                            <t t-foreach="line_data['vdp']['field_names']" t-as="field_name">
                                                <th t-out="field_name"/>
                                            </t>
                                            <t t-if="not line_data['vdp']['field_names']">
                                                <th>Data</th>
                                            </t>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="line_data['vdp']['rows']" t-as="vdp_row">
                                            <td t-out="vdp_row['name']"/>
                                            <td t-out="vdp_row['state']"/>
                                            <t t-if="line_data['vdp']['field_names']">
                                                <td t-foreach="vdp_row['columns']" t-as="cell_value">
                                                    <span t-out="cell_value"/>
                                                </td>
                                            </t>
                                            <t t-else="">
                                                <td t-out="vdp_row['values_display']"/>
                                            </t>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </div>
                </t>

                <div class="text-muted mt-4 small">
                    Generated on <span t-out="generation_date_display"/>
                </div>
            </div>
        </t>
    </template>

    <template id="report_production_sheet">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="tus_product_personalizer.report_production_sheet_document"
                   t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>

</odoo>
